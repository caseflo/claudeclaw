# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (send /chatid to your bot after first run)
ALLOWED_CHAT_ID=your_chat_id_here

# ─── Google AI (Memory v2, War Room, video analysis) ─────────────────────────
# Free at https://aistudio.google.com
GOOGLE_API_KEY=

# ─── Voice STT ───────────────────────────────────────────────────────────────
# Groq — free tier, very generous. Get at https://console.groq.com
GROQ_API_KEY=

# OpenAI — fallback STT (paid). Omit if using Groq.
# OPENAI_API_KEY=

# ─── Voice TTS ───────────────────────────────────────────────────────────────
# ElevenLabs — free tier available. Get at https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Kokoro — local OpenAI-compatible TTS server (no API key needed)
# KOKORO_URL=http://localhost:8880

# ─── Security ────────────────────────────────────────────────────────────────
# PIN hash — generate with: tsx -e "import {hashPIN} from './src/security.js'; console.log(hashPIN('your_pin'))"
# PIN_HASH=salt:hash

# Kill phrase — emergency shutdown
# KILL_PHRASE=your_secret_phrase

# Idle lock timeout in minutes (default: 30)
# IDLE_LOCK_MINUTES=30

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Token to access dashboard at http://localhost:3141?token=TOKEN
DASHBOARD_TOKEN=changeme_set_this

# ─── Optional features ────────────────────────────────────────────────────────
# FEATURE_VOICE=true
# FEATURE_SCHEDULER=true
# FEATURE_DASHBOARD=true
# FEATURE_WAR_ROOM=true
# FEATURE_SECURITY=true
# FEATURE_MULTI_AGENT=true
# FEATURE_MEETING_BOT=false

# ─── War Room (Python voice room) ────────────────────────────────────────────
# WARROOM_MODE=live         # 'live' (Gemini) or 'legacy' (Deepgram+Cartesia)
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=

# ─── Agent settings ───────────────────────────────────────────────────────────
# DEFAULT_AGENT_MODEL=claude-sonnet-4-6
# AGENT_MAX_TURNS=30
# AGENT_TIMEOUT_MS=900000

# ─── Memory ───────────────────────────────────────────────────────────────────
# MEMORY_MODE=full_v2       # 'full_v2' | 'simple' | 'none'
# MEMORY_SIMPLE_TURNS=20

# ─── Cost footer ─────────────────────────────────────────────────────────────
# SHOW_COST_FOOTER=compact  # 'compact' | 'verbose' | 'cost' | 'full' | 'off'
